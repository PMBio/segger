  local current_status=""
  trap - EXIT INT TERM HUP
  if [[ -f /omics/groups/OE0606/internal/elihei/projects/segger_lsf_benchmark_fixed/datasets/xenium_mouse_brain/runs/use3d_true/.segment_status ]]; then
