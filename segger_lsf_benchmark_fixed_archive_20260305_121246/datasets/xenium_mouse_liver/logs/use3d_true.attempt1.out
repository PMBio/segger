    *) printf '%s_error' segment ;;
  esac
}

on_primary_exit() {
  local rc=$?
  local current_status=""
  trap - EXIT INT TERM HUP
  if [[ -f /omics/groups/OE0606/internal/elihei/projects/segger_lsf_benchmark_fixed/datasets/xenium_mouse_liver/runs/use3d_true/.segment_status ]]; then
    current_status="$(awk -F'=' '$1 == \"segment_status\" { print $2; exit }' /omics/groups/OE0606/internal/elihei/projects/segger_lsf_benchmark_fixed/datasets/xenium_mouse_liver/runs/use3d_true/.segment_status 2>/dev/null || true)"
  fi
  if [[ "${rc}" -ne 0 ]] && [[ "${current_status}" != segment_ok ]]; then
    write_segment_status "$(classify_segment_status "${rc}")" "${rc}"
  elif [[ -z "${current_status}" ]]; then
    write_segment_status "pending" "${rc}"
  fi
  exit "${rc}"
}

