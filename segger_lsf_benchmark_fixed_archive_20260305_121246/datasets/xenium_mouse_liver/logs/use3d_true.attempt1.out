write_segment_status() {
  local stage_status="$1"
  local stage_rc="${2:-0}"
  printf 'segment_status=%s\nsegment_rc=%s\n' "${stage_status}" "${stage_rc}" > /omics/groups/OE0606/internal/elihei/projects/segger_lsf_benchmark_fixed/datasets/xenium_mouse_liver/runs/use3d_true/.segment_status
}

classify_segment_status() {
  local stage_rc="$1"
  case "${stage_rc}" in
