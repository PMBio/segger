set -euo pipefail

write_segment_status() {
  local stage_status="$1"
  local stage_rc="${2:-0}"
  printf 'segment_status=%s\nsegment_rc=%s\n' "${stage_status}" "${stage_rc}" > /omics/groups/OE0606/internal/elihei/projects/segger_lsf_benchmark_fixed/datasets/xenium_v1_colon/runs/pred_sf3p2_fragoff/.segment_status
}

classify_segment_status() {
  local stage_rc="$1"
  case "${stage_rc}" in
    137|140) printf '%s_oom' predict ;;
    138|143) printf '%s_runlimit' predict ;;
    *) printf '%s_error' predict ;;
  esac
}

on_primary_exit() {
  local rc=$?
  local current_status=""
  trap - EXIT INT TERM HUP
  if [[ -f /omics/groups/OE0606/internal/elihei/projects/segger_lsf_benchmark_fixed/datasets/xenium_v1_colon/runs/pred_sf3p2_fragoff/.segment_status ]]; then
    current_status="$(awk -F'=' '$1 == \"segment_status\" { print $2; exit }' /omics/groups/OE0606/internal/elihei/projects/segger_lsf_benchmark_fixed/datasets/xenium_v1_colon/runs/pred_sf3p2_fragoff/.segment_status 2>/dev/null || true)"
  fi
  if [[ "${rc}" -ne 0 ]] && [[ "${current_status}" != predict_ok ]]; then
    write_segment_status "$(classify_segment_status "${rc}")" "${rc}"
  elif [[ -z "${current_status}" ]]; then
    write_segment_status "pending" "${rc}"
  fi
  exit "${rc}"
}

trap on_primary_exit EXIT INT TERM HUP

